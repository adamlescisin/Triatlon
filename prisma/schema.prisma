generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  username  String   @unique
  password  String
  name      String
  role      String
  createdAt DateTime @default(now())
  timekeeperTeamMembers TimekeeperTeamMember[]
  timeRecords           TimeRecord[]
  announcerAlerts       AnnouncerAlert[]
  accounts              Account[]
  sessions              Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Season {
  id        String   @id @default(cuid())
  year      Int
  name      String
  date      DateTime
  location  String
  status    String   @default("preparing")
  createdAt DateTime @default(now())
  categories  Category[]
  checkpoints Checkpoint[]
}

model Category {
  id          String    @id @default(cuid())
  seasonId    String
  name        String
  color       String
  type        String
  startOrder  Int       @default(0)
  startTime   DateTime?
  createdAt   DateTime  @default(now())
  season          Season           @relation(fields: [seasonId], references: [id])
  entries         Entry[]
  timekeeperTeams TimekeeperTeam[]
}

model Checkpoint {
  id       String  @id @default(cuid())
  seasonId String
  type     String
  order    Int
  optional Boolean @default(false)
  label    String
  season      Season       @relation(fields: [seasonId], references: [id])
  timeRecords TimeRecord[]
}

model Athlete {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  dateOfBirth      DateTime?
  photoUrl         String?
  emergencyContact String?
  createdAt        DateTime  @default(now())
  entries    Entry[]
  relaySlots RelaySlot[]
}

model Entry {
  id         String   @id @default(cuid())
  seasonId   String
  categoryId String
  athleteId  String?
  bibNumber  Int
  type       String
  status     String   @default("registered")
  createdAt  DateTime @default(now())
  category        Category         @relation(fields: [categoryId], references: [id])
  athlete         Athlete?         @relation(fields: [athleteId], references: [id])
  relayTeam       RelayTeam?
  timeRecords     TimeRecord[]
  lapRecords      LapRecord[]
  announcerAlerts AnnouncerAlert[]
  @@unique([seasonId, bibNumber])
}

model RelayTeam {
  id      String @id @default(cuid())
  entryId String @unique
  name    String
  entry Entry     @relation(fields: [entryId], references: [id])
  slots RelaySlot[]
}

model RelaySlot {
  id          String @id @default(cuid())
  relayTeamId String
  athleteId   String
  segment     String
  relayTeam RelayTeam @relation(fields: [relayTeamId], references: [id])
  athlete   Athlete   @relation(fields: [athleteId], references: [id])
}

model TimekeeperTeam {
  id         String @id @default(cuid())
  categoryId String
  name       String
  category Category               @relation(fields: [categoryId], references: [id])
  members  TimekeeperTeamMember[]
}

model TimekeeperTeamMember {
  id               String @id @default(cuid())
  timekeeperTeamId String
  userId           String
  team TimekeeperTeam @relation(fields: [timekeeperTeamId], references: [id])
  user User           @relation(fields: [userId], references: [id])
}

model TimeRecord {
  id           String   @id @default(cuid())
  entryId      String
  checkpointId String
  timestamp    DateTime
  timekeeperId String
  deviceId     String?
  note         String?
  isCorrection Boolean  @default(false)
  corrects     String?
  createdAt    DateTime @default(now())
  entry      Entry      @relation(fields: [entryId], references: [id])
  checkpoint Checkpoint @relation(fields: [checkpointId], references: [id])
  timekeeper User       @relation(fields: [timekeeperId], references: [id])
}

model LapRecord {
  id        String   @id @default(cuid())
  entryId   String
  lapNumber Int
  timestamp DateTime
  createdAt DateTime @default(now())
  entry Entry @relation(fields: [entryId], references: [id])
}

model AnnouncerAlert {
  id             String   @id @default(cuid())
  entryId        String?
  checkpointType String
  message        String
  authorId       String
  createdAt      DateTime @default(now())
  entry  Entry? @relation(fields: [entryId], references: [id])
  author User   @relation(fields: [authorId], references: [id])
}
